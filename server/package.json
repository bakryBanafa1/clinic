{
  "name": "clinic-server",
  "version": "1.0.0",
  "description": "Clinic Management System - Backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.0",
    "@whiskeysockets/baileys": "^6.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "5.22.0"
  }
}